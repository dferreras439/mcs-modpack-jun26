# Shared paths
PACK_DIR="./publish"
BIN_DIR="./bin"

# Source selector: curseforge, modrinth, empty, or local
MODPACK_SOURCE="curseforge"

# Packwiz metadata. For local ZIP/manifest CurseForge sources, these can be derived
# from manifest.json when present. For CF_PAGE_URL/CF_SLUG sources, set them here.
PACK_NAME="Create Aeronautics - Skybound - MC 1.21.1"
PACK_VERSION="4.1.0"
MC_VERSION="1.21.1"
MODLOADER="neoforge"
MODLOADER_VERSION="21.1.233"

# CurseForge source. Use one of CF_PAGE_URL, CF_SLUG, CF_MODPACK_ZIP,
# CF_MODPACK_MANIFEST, or legacy MODPACK_ZIP_URL.
# Values are parsed literally, so API keys containing $ are safe in either "..." or '...'.
CF_API_KEY=""
CF_PAGE_URL=""
CF_SLUG=""
CF_FILE_ID=""
CF_FILENAME_MATCHER=""
CF_MODPACK_ZIP=""
CF_MODPACK_MANIFEST=""
MODPACK_ZIP_URL=""
CF_DOWNLOADS_REPO="./downloads"

# Optional CurseForge filtering
CF_EXCLUDE_MODS=""
CF_FORCE_INCLUDE_MODS=""
CF_EXCLUDE_ALL_MODS="false"
CF_OVERRIDES_EXCLUSIONS=""
CF_IGNORE_MISSING_FILES=""

# Modrinth source
MODRINTH_PROJECT=""
MODRINTH_VERSION=""
MODRINTH_GAME_VERSION=""
MODRINTH_LOADER=""

# Cloudflare R2 publish via rclone. Either set RCLONE_DEST directly or set
# R2_BUCKET plus the R2 credentials below.
RCLONE_REMOTE="r2"
RCLONE_DEST=""
R2_BUCKET=""
R2_PREFIX=""
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
PUBLISH_DRY_RUN="false"
